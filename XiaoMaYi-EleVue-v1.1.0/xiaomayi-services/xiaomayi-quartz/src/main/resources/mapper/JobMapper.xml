<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaomayi.quartz.mapper.JobMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xiaomayi.quartz.entity.Job">
        <id column="id" property="id" />
        <result column="job_name" property="jobName" />
        <result column="job_alias" property="jobAlias" />
        <result column="job_group" property="jobGroup" />
        <result column="job_trigger" property="jobTrigger" />
        <result column="status" property="status" />
        <result column="cron_expression" property="cronExpression" />
        <result column="execute_policy" property="executePolicy" />
        <result column="is_sync" property="isSync" />
        <result column="url" property="url" />
        <result column="note" property="note" />
        <result column="create_user" property="createUser" />
        <result column="create_time" property="createTime" />
        <result column="update_user" property="updateUser" />
        <result column="update_time" property="updateTime" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        job_id, job_name, job_alias, job_group, job_trigger, status, cron_expression, execute_policy, is_sync, url, note, create_user, create_time, update_user, update_time, del_flag
    </sql>

</mapper>